# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=BOCRA Platform API
APP_ENV=development
DEBUG=false

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default for local dev):
# DATABASE_URL=sqlite:///./bocra_dev.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/bocra
# Render-style Postgres URLs also work:
# DATABASE_URL=postgresql://user:password@host:5432/bocra

# ── Auth ──────────────────────────────────────────────────────────────────────
LOCAL_AUTH_SALT=change-this-to-a-long-random-string
SESSION_TTL_HOURS=24

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Cloudinary (primary file storage) ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>
CLOUDINARY_FOLDER=bocra

# ── Supabase (auth + optional storage fallback) ────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_STORAGE_BUCKET=bocra-files

# ── Google AI ─────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=<your-google-api-key>
GOOGLE_AI_MODEL=gemini-2.5-flash
